{
  "name": "beacon-bazaar",
  "version": "1.0.0",
  "private": true,
  "description": "Konum bazlı e-ticaret platformu - Beacon Bazaar",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && ../../node_modules/.bin/vite",
    "dev:mobile": "yarn workspace @beacon-bazaar/mobile start",
    "dev:backend": "cd apps/backend && ../../node_modules/.bin/nest start --watch",
    "build:web": "yarn workspace @beacon-bazaar/web build",
    "build:shared": "yarn workspace @beacon-bazaar/shared build",
    "build:backend": "yarn workspace @beacon-bazaar/backend build",
    "lint": "yarn workspaces foreach -A run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "yarn workspaces foreach -A run test",
    "clean": "yarn workspaces foreach -A run clean"
  },
  "engines": {
    "node": "20.x",
    "yarn": ">=1.22.0"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@expo/ngrok": "^4.1.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "typescript": "^5.3.0"
  }
}
