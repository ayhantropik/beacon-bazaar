## Mobile env örneği — bu dosyayı .env adıyla kopyala ve değerleri doldur
## .env git'e commit edilmemeli

# Kalıcı backend URL (Render/Railway/vs.) — mobil bilgisayardan bağımsız çalışsın diye sabit
API_BASE_URL=https://venividicoop-api.onrender.com/api/v1

# Yerel geliştirme tunneli (opsiyonel) — bilgisayar açıkken kullanmak için
# Cloudflare quick tunnel scripts/tunnel-watchdog.sh tarafından otomatik güncellenir
API_BASE_URL_LOCAL=
# true → API_BASE_URL_LOCAL kullanılır, false/boş → API_BASE_URL (kalıcı) kullanılır
USE_LOCAL_TUNNEL=false

# Azure Maps anahtarı (zorunlu — harita gösterimi için)
AZURE_MAPS_KEY=

# Google OAuth (opsiyonel — sosyal autofill için)
GOOGLE_AUTH_CLIENT_ID=

# Facebook OAuth (opsiyonel)
FACEBOOK_APP_ID=
